# Server
DATABASE_URL=postgresql://pqp:pqp@localhost:5432/pqp
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
PORT=3001

# Set NODE_ENV=production in prod. DEV_AUTH_BYPASS below is ignored when it is.
# NODE_ENV=production

# Restrict which Clerk authorized parties (origins) are accepted (comma-separated).
CLERK_AUTHORIZED_PARTIES=

# Restrict CORS to these origins (comma-separated). Empty = allow all (*).
CORS_ALLOWED_ORIGINS=

# Postgres pool: set DATABASE_SSL=true for managed Postgres over public networking.
DATABASE_SSL=
# PG_POOL_MAX=10

# Local dev: skip Clerk — use token "dev-local-token" (server + client must both enable)
# Ignored when NODE_ENV=production.
DEV_AUTH_BYPASS=true

# Client (copy to client/.env — Vite requires VITE_ prefix)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
VITE_DEV_AUTH_BYPASS=true
VITE_API_URL=
VITE_WS_URL=

# TURN — preferred on the API (served via GET /api/ice-servers)
# Option A: static long-term credentials
TURN_URL=turn:your-turn-server.example.com:3478
TURN_USERNAME=your-username
TURN_CREDENTIAL=your-credential

# Option B: Cloudflare Realtime TURN (recommended for production)
# Create a TURN key in Cloudflare Dashboard → Realtime → TURN
CLOUDFLARE_TURN_KEY_ID=
CLOUDFLARE_TURN_API_TOKEN=

# Option C: Metered / Open Relay REST API
METERED_API_KEY=
METERED_DOMAIN=

# Optional client-side TURN fallback (baked into Pages build — prefer API instead)
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
# Voice backend: mesh (default) | cloudflare-sfu (hosted) | livekit (self-host)
VITE_VOICE_BACKEND=mesh

# Cloudflare Realtime SFU (hosted, Phase 5)
CLOUDFLARE_REALTIME_APP_ID=
CLOUDFLARE_REALTIME_APP_SECRET=

# LiveKit (self-host, Phase 5)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Electron
VITE_APP_URL=http://localhost:5173
